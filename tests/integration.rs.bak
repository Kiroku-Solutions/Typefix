}

/// Test combining characters (accented text)
#[test]
fn test_combining_characters() {
    let buffer = CharBuffer::new();

    // e + combining acute accent = é
    let text = "café résumé naïve";
    let tokens = buffer.push_string(text);

    assert!(tokens.contains(&"café".to_string()) || tokens.contains(&"cafe".to_string()));
}

/// Test zero-width characters (edge case)
#[test]
fn test_zero_width_characters() {
    let buffer = CharBuffer::new();

    // Zero-width space and joiner
    let text = "hello\u{200B}world\u{200D}test";
    let tokens = buffer.push_string(text);

    // Should not crash, may or may not extract (depends on delimiting)
    assert!(!tokens.is_empty() || tokens.is_empty()); // Either is fine
}

/// Test numbers only
#[test]
fn test_numbers_only() {
    let buffer = CharBuffer::new();
    let tokens = buffer.push_string("12345 67890");

    assert_eq!(tokens.len(), 2);
    assert_eq!(tokens[0], "12345");
    assert_eq!(tokens[1], "67890");
}

/// Test mixed scripts (Latin + CJK + Arabic)
#[test]
fn test_mixed_scripts() {
    let buffer = CharBuffer::new();

    let text = "hello 世界 مرحبا";
    let tokens = buffer.push_string(text);

    // Should handle without crashing
    assert!(tokens.len() >= 2);
}

/// Test pipeline concurrent processing
#[test]
fn test_pipeline_concurrent_word_processing() {
    use std::sync::Arc;
    use parking_lot::RwLock;

    let pipeline = Arc::new(typo_engine::TypoPipeline::simple());
    let results = Arc::new(RwLock::new(Vec::new()));
    let results_clone = Arc::clone(&results);

    std::thread::scope(|s| {
        // Thread 1: English text
        s.spawn(|| {
            let r = pipeline.process_string("hello world");
            results_clone.write().extend(r);
        });
        // Thread 2: Another English text
        s.spawn(|| {
            let r = pipeline.process_string("testing pipeline");
            results_clone.write().extend(r);
        });
    });

    // Both threads should complete without crash
    let captured = results.read();
    assert!(!captured.is_empty());
}

/// Test static map JSON size limit (security)
#[test]
fn test_static_map_json_size_limit() {
    use typo_engine::correction::StaticErrorMap;

    // Create a huge JSON string (>1MB)
    let huge_json = format!(
        r#"{{"language": "en", "errors": {{"a": "b", "c": "d", "x": "{}"}}}}"#,
        "x".repeat(2 * 1024 * 1024)
    );

    let result = StaticErrorMap::from_json(&huge_json);
    assert!(result.is_err()); // Should reject due to size
}

/// Test very large dictionary
#[test]
fn test_large_dictionary_performance() {
    use std::time::Instant;

    let mut trie = typo_engine::core::Trie::new();

    // Insert 50,000 words
    for i in 0..50_000 {
        trie.insert(&format!("word{}", i), i as u64);
    }

    // Search should still be fast (O(m))
    let start = Instant::now();
    for _ in 0..1000 {
        let _ = trie.search("word25000");
    }
    let elapsed = start.elapsed();

    // Should complete in under 100ms for 1000 searches
    assert!(elapsed.as_millis() < 100, "Search too slow: {:?}", elapsed);
}

/// Test pipeline with alternating languages
#[test]
fn test_alternating_language_switches() {
    let pipeline = typo_engine::TypoPipeline::simple();

    // Alternate between English and Spanish
    let text = "the el quick rápido brown perro";
    let results = pipeline.process_string(text);

    // Should process all words without crashing
    assert_eq!(results.len(), 6);
}

/// Test static map user errors persistence simulation
#[test]
fn test_static_map_learn_and_persist() {
    use std::io::Write;
    use std::fs;

    let map = typo_engine::correction::StaticErrorMap::new("test");

    // Learn some corrections
    map.learn("typo1", "typo one");
    map.learn("typo2", "typo two");

    // Save to temp file
    let temp_path = std::env::temp_dir().join("typo_engine_test_errors.json");
    let save_result = map.save_user_errors(&temp_path);
    assert!(save_result.is_ok());

    // Load in new map
    let map2 = typo_engine::correction::StaticErrorMap::new("test2");
    let load_result = map2.load_user_errors(&temp_path);
    assert!(load_result.is_ok());
    assert_eq!(map2.lookup("typo1"), Some("typo one".to_string()));

    // Cleanup
    let _ = fs::remove_file(&temp_path);
}
